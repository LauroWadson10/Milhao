  m_EditorClassIdentifier: Assembly-CSharp::QuestaoSO
  txtQuestao: "A semelhan\xE7a na distribui\xE7\xE3o dos versos entre o poema original
    e a par\xF3dia permite ao leitor perceber que:"
  opcao:
  - "A forma do poema contribui para a constru\xE7\xE3o do efeito de surpresa final.\t\t\t\t\t\t\t\t\t "
  - "A par\xF3dia ignora completamente a forma do texto original.\t\t\t\t\t\t\t\t\t "
  - "A organiza\xE7\xE3o dos versos n\xE3o interfere no sentido do texto.\t\t\t\t\t\t\t\t\t "
  - "O texto parodiado perde seu efeito cr\xEDtico.\t\t\t\t\t\t\t\t\t "
  Nivel: 1
  imgQuestao: []
  correto: 01000000
  Ajuda: "A forma como os versos s\xE3o organizados no poema pode contribuir para
    a constru\xE7\xE3o de sentidos."
